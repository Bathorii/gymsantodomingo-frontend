# Production environment template for Railway / Vercel deployment
# Copy to .env.production.local and update the API_URL after Railway deployment
#
# After deploying gymbook-api to Railway, replace the placeholder URL below
# with the actual Railway-assigned URL (e.g., https://gymbook-api-abc123.up.railway.app)

NEXT_PUBLIC_CITY_SLUG=bogota
NEXT_PUBLIC_CITY_NAME=Bogotá
NEXT_PUBLIC_COUNTRY=CO
NEXT_PUBLIC_LANG=es-CO
NEXT_PUBLIC_DOMAIN=gymbogota.co
NEXT_PUBLIC_CDN_URL=https://cdn.gymbook.app
NEXT_PUBLIC_API_URL=https://gymbook-api.up.railway.app
